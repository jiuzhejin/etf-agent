# DeepSeek 走 Anthropic 格式端点，复用 anthropic SDK，只需换 base_url/key/model
# key 可直接填 sk-...，或留 ${DEEPSEEK_API_KEY} 从 shell 环境读取
LLM_API_KEY=${DEEPSEEK_API_KEY}
LLM_BASE_URL=https://api.deepseek.com/anthropic

# 研报分析模型 → 思考型（质量优先）；deepseek-reasoner（思考）/ deepseek-chat（非思考）
LLM_MODEL=deepseek-reasoner
# 关键词提取 / 基金编码解析 / JSON 修复 → 便宜快模型（机械任务，省钱优先）
LLM_MODEL_FAST=deepseek-chat
